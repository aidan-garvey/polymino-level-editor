{
  "extends": ["@vue/tsconfig/tsconfig.dom.json", "./tsconfig.base.json"],
  "include": [
    "env.d.ts",
    "src/**/*",
    "src/**/*.vue",
    "./auto-imports.d.ts",
    "./components.d.ts",
    "./runtime-dom.d.ts",
  ],
  "exclude": ["src/**/__tests__/*"],
  "compilerOptions": {
    // Bumped up from ES2020 inherited from Vue, adds Array.prototype.at and
    // Object.hasOwn, etc. Other elements are the same as Vue.
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "tsBuildInfoFile": "./node_modules/.tmp/tsconfig.app.tsbuildinfo",

    "paths": {
      "@/*": ["./src/*"]
    }
  },
  "vueCompilerOptions": {
    "strictTemplates": true,
    // Enabling this will emit errors when listening for native events which
    // bubble from a component's child elements.
    "checkUnknownEvents": false,
  }
}
